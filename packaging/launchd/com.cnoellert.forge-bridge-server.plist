<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cnoellert.forge-bridge-server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/forge-bridge-server-daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>UserName</key>
    <string>__SUDO_USER__</string>
    <key>WorkingDirectory</key>
    <string>/Users/__SUDO_USER__</string>
    <key>StandardOutPath</key>
    <string>/var/log/forge-bridge/server.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/forge-bridge/server.log</string>
</dict>
</plist>
