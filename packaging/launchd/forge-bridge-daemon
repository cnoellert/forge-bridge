#!/usr/bin/env bash
# /usr/local/bin/forge-bridge-daemon
# macOS wrapper for MCP+Console.
#
# Phase A.4 (2026-05-05): the bus-readiness gate (formerly a 30s `nc -z`
# poll loop here) now lives inside the daemon's `bootstrap_daemon()` so
# every entry point (this launchd path, `fbridge up`, direct `mcp http`,
# `mcp stdio`) inherits the same wait. Override the default 30s wait via
# FORGE_BRIDGE_BUS_WAIT_SECONDS in /etc/forge-bridge/forge-bridge.env.
set -euo pipefail

if [ -f /etc/forge-bridge/forge-bridge.env ]; then
    set -a
    . /etc/forge-bridge/forge-bridge.env
    set +a
fi

exec "${FORGE_PYTHON:-/Users/__SUDO_USER__/miniconda3/envs/forge/bin/python}" \
     -m forge_bridge mcp http --port 9997
