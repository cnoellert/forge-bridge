#!/usr/bin/env bash
# /usr/local/bin/forge-bridge-daemon
# macOS wrapper for MCP+Console.
#
# Phase A.4 (2026-05-05): the bus-readiness gate (formerly a 30s `nc -z`
# poll loop here) now lives inside the daemon's `bootstrap_daemon()` so
# every entry point (this launchd path, `fbridge up`, direct `mcp http`,
# `mcp stdio`) inherits the same wait. Override the default 30s wait via
# FORGE_BRIDGE_BUS_WAIT_SECONDS in /etc/forge-bridge/forge-bridge.env.
set -euo pipefail

if [ -f /etc/forge-bridge/forge-bridge.env ]; then
    set -a
    . /etc/forge-bridge/forge-bridge.env
    set +a
fi

FORGE_PYTHON="${FORGE_PYTHON:-/Users/__SUDO_USER__/miniconda3/envs/forge/bin/python}"

# launchd starts daemons with a minimal PATH (/usr/bin:/bin:/usr/sbin:/sbin)
# that excludes the conda env's bin/. Operators that shell out to env binaries
# — e.g. sibling perception tools decoding plate video via ffmpeg — then fail
# with "ffmpeg is required". Prepend the interpreter's own bin dir so those
# binaries resolve. Same interpreter, now with its toolchain on PATH.
export PATH="$(dirname "$FORGE_PYTHON"):${PATH}"

exec "$FORGE_PYTHON" -m forge_bridge mcp http --port 9997
