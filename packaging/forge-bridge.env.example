# packaging/forge-bridge.env.example
# This file is the SINGLE source of truth for forge-bridge daemon configuration.
# Both systemd (via EnvironmentFile=) and launchd wrapper scripts source it.
# Edit and run:
#   sudo systemctl restart forge-bridge   (Linux)
#   sudo launchctl kickstart -k system/com.cnoellert.forge-bridge   (macOS)
#
# See docs/INSTALL.md for end-to-end install path.

# ─── Postgres ─────────────────────────────────────────────────────────────
# Default matches alembic.ini hardcoded URL + forge_bridge/store/session.py default.
FORGE_DB_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge_bridge

# ─── Local LLM (Ollama) ───────────────────────────────────────────────────
# Most operators run Ollama on a SEPARATE LLM service host on the same network.
# Set this to your LLM host's URL, e.g.:
#   FORGE_LOCAL_LLM_URL=http://192.168.86.15:11434/v1
# Default below assumes Ollama is local — only use that on hosts with dedicated GPU/RAM.
FORGE_LOCAL_LLM_URL=http://localhost:11434/v1

# Locked default per SEED-DEFAULT-MODEL-BUMP-V1.4.x — DO NOT change to qwen3:32b
# (cold-start LLMLoopBudgetExceeded driven by thinking-mode token verbosity).
FORGE_LOCAL_MODEL=qwen2.5-coder:32b

# ─── Cloud LLM (Anthropic) — OPTIONAL ─────────────────────────────────────
# Chat hardcodes sensitive=True (routes through local Ollama). Cloud is only used
# for sensitive=False routing — not the daily operator workflow.
ANTHROPIC_API_KEY=
# Locked default per SEED-OPUS-4-7-TEMPERATURE-V1.5 — do not change without
# reading that seed (AnthropicAdapter sends temperature; newer models reject it).
FORGE_CLOUD_MODEL=claude-sonnet-4-6

# ─── Ports ────────────────────────────────────────────────────────────────
# MCP server + Artist Console (forge_bridge.__main__).
FORGE_CONSOLE_PORT=9996
# WebSocket bus (forge_bridge.server).
FORGE_BRIDGE_PORT=9998

# ─── Flame hook bind host (Track A only) ──────────────────────────────────
# Flame hook listens on FORGE_BRIDGE_HOST:9999 — daemons do NOT consume this var
# but the env file documents it for operator visibility.
FORGE_BRIDGE_HOST=127.0.0.1
