# packaging/forge-bridge.env.example
# This file is the SINGLE source of truth for forge-bridge daemon configuration.
# Both systemd (via EnvironmentFile=) and launchd wrapper scripts source it.
# Edit and run:
#   sudo systemctl restart forge-bridge   (Linux)
#   sudo launchctl kickstart -k system/com.cnoellert.forge-bridge   (macOS)
#
# See docs/INSTALL.md for end-to-end install path.

# ─── Postgres ─────────────────────────────────────────────────────────────
# Default matches alembic.ini hardcoded URL + forge_bridge/store/session.py default.
FORGE_DB_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge_bridge

# ─── Local LLM (Ollama) ───────────────────────────────────────────────────
# Most operators run Ollama on a SEPARATE LLM service host on the same network.
# Set this to your LLM host's URL, e.g.:
#   FORGE_LOCAL_LLM_URL=http://192.168.86.15:11434/v1
# Default below assumes Ollama is local — only use that on hosts with dedicated GPU/RAM.
FORGE_LOCAL_LLM_URL=http://localhost:11434/v1

# Phase 24.3 swap from qwen2.5-coder:32b. 32b baseline produced 0 tokens cold +
# never-terminating warm probes under the canonical query — see
# .planning/milestones/v1.6-PHASE-24-3-BASELINE-32B.md. DO NOT change to qwen3:32b
# (cold-start LLMLoopBudgetExceeded driven by thinking-mode token verbosity per
# the prior SEED-DEFAULT-MODEL-BUMP-V1.4.x archaeology).
FORGE_LOCAL_MODEL=qwen2.5-coder:14b

# ─── Cloud LLM (Anthropic) — OPTIONAL ─────────────────────────────────────
# Chat hardcodes sensitive=True (routes through local Ollama). Cloud is only used
# for sensitive=False routing — not the daily operator workflow.
ANTHROPIC_API_KEY=
# Locked default per SEED-OPUS-4-7-TEMPERATURE-V1.5 — do not change without
# reading that seed (AnthropicAdapter sends temperature; newer models reject it).
FORGE_CLOUD_MODEL=claude-sonnet-4-6

# ─── Ports ────────────────────────────────────────────────────────────────
# Each daemon role has its own env var (see forge_bridge/config.py). Do NOT
# conflate FORGE_BRIDGE_PORT (Flame HTTP bridge client target — read by
# forge_bridge/bridge.py:35 to dispatch flame_execute_python and similar
# tools) with FORGE_STATE_WS_PORT (WebSocket bus bind port — read by
# forge_bridge/config.py:state_ws_port). Crossing the two silently routes
# the bridge client at the WebSocket port, which RSTs every HTTP POST and
# produces "Bridge communication error: Server disconnected without sending
# a response" in chat. Phase 24.2 doctor row surfaces this divergence as
# "dispatch target mismatch — daemon=... shell=..." but only when both
# surfaces are observable; keep the env file's role mapping correct.
#
# MCP server + Artist Console (forge_bridge.__main__).
FORGE_CONSOLE_PORT=9996
# WebSocket bus (forge_bridge.server.__main__).
FORGE_STATE_WS_PORT=9998
# Flame HTTP bridge client target (Flame hook listens on this port).
# Default matches what scripts/install-flame-hook.sh deploys.
FORGE_BRIDGE_PORT=9999

# ─── Flame hook bind host (Track A only) ──────────────────────────────────
# Flame hook listens on FORGE_BRIDGE_HOST:FORGE_BRIDGE_PORT. The daemon's
# bridge client reads both vars to construct its dispatch URL.
FORGE_BRIDGE_HOST=127.0.0.1

# ─── MCP HTTP transport port ─────────────────────────────────────────────────
# Port for FastMCP to bind under streamable-http / sse daemon transports.
# Read by forge-bridge.service and com.cnoellert.forge-bridge.plist via env file.
# Ignored under stdio transport (Claude Desktop / Claude Code stdio invocations).
FORGE_MCP_PORT=9997
